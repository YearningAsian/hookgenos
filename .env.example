# ── Database ────────────────────────────────────────────────────────────────
# CHANGE the password before any non-local deployment.
DATABASE_URL=postgresql://hookgenos:hookgenos@localhost:5432/hookgenos
POSTGRES_USER=hookgenos
POSTGRES_PASSWORD=hookgenos
POSTGRES_DB=hookgenos

# ── Redis (optional — rate-limit / trending cache) ──────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth (required) ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# The API refuses to start in production if this is not set.
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# ── OpenAI (optional — enables AI-powered generation) ───────────────────────
OPENAI_API_KEY=
# Model used for AI generation (default: gpt-4o-mini)
OPENAI_MODEL=

# ── Stripe (optional — enables the Pro subscription tier) ───────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO_MONTHLY=

# ── App URLs ─────────────────────────────────────────────────────────────────
# URL the browser uses to reach the API
NEXT_PUBLIC_API_URL=http://localhost:3001
# Canonical URL of the frontend (used for CORS + Stripe redirect URLs)
APP_URL=http://localhost:3000
NODE_ENV=development

{
  "name": "hookgenos-monorepo",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "engines": { "node": ">=20.19", "pnpm": ">=9" },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=@hookgenos/api",
    "dev:app": "turbo run dev --filter=@hookgenos/app",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "db:generate": "pnpm --filter @hookgenos/database generate",
    "db:migrate": "pnpm --filter @hookgenos/database migrate",
    "db:migrate:deploy": "pnpm --filter @hookgenos/database migrate:deploy",
    "db:push": "pnpm --filter @hookgenos/database push",
    "db:seed": "pnpm --filter @hookgenos/database seed",
    "db:studio": "pnpm --filter @hookgenos/database studio",
    "start": "pnpm --filter @hookgenos/api start"
  },
  "devDependencies": {
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "@types/node": "^24.13.2"
  },
  "pnpm": {
    "overrides": {
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "postcss@>=8.0.0 <8.5.10": ">=8.5.10",
      "@hono/node-server@<1.19.13": ">=1.19.13"
    }
  }
}

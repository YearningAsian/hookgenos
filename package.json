{
  "name": "hookgenos-monorepo",
  "version": "0.1.0",
  "private": true,
  "engines": { "node": ">=20", "pnpm": ">=9" },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=@hookgenos/api",
    "dev:app": "turbo run dev --filter=@hookgenos/app",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "db:generate": "pnpm --filter @hookgenos/database prisma generate",
    "db:migrate": "pnpm --filter @hookgenos/database prisma migrate dev",
    "db:push": "pnpm --filter @hookgenos/database prisma db push",
    "db:studio": "pnpm --filter @hookgenos/database prisma studio",
    "start": "pnpm --filter @hookgenos/api start"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}

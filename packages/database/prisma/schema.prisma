generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  FREE
  PRO
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  passwordHash         String
  name                 String?
  plan                 Plan                 @default(FREE)
  hooksGenerated       Int                  @default(0)
  stripeCustomerId     String?              @unique
  stripeSubscriptionId String?              @unique
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  hooks                GeneratedHook[]
  apiKeys              ApiKey[]
  passwordResetTokens  PasswordResetToken[]
  boards               Board[]

  @@index([email])
  @@index([stripeCustomerId])
  @@map("users")
}

model GeneratedHook {
  id         String   @id @default(cuid())
  userId     String
  content    String
  platform   String
  niche      String?
  tone       String
  topic      String
  hookType   String
  score      Int      @default(0)
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([userId, isFavorite])
  @@map("generated_hooks")
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  name      String
  keyHash   String    @unique
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

// A swipe-file board: a user-owned collection of saved hooks.
model Board {
  id        String      @id @default(cuid())
  userId    String
  name      String
  color     String      @default("#9333ea")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  hooks     BoardHook[]

  @@index([userId])
  @@index([userId, updatedAt])
  @@map("boards")
}

// A saved hook inside a board. Stored as a denormalized snapshot because the
// source hook may be a curated library item, a ripped URL, or a generated hook
// — none of which are guaranteed to exist as a persistent row.
model BoardHook {
  id           String   @id @default(cuid())
  boardId      String
  text         String
  hookType     String
  platform     String
  score        Int      @default(0)
  niche        String?
  sourceHandle String?
  sourceViews  String?
  createdAt    DateTime @default(now())

  board        Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId])
  @@index([boardId, createdAt])
  @@map("board_hooks")
}

model TrendingHook {
  id          String   @id @default(cuid())
  text        String
  platform    String
  hookType    String
  score       Int      @default(0)
  niche       String?
  sourceType  String   // 'youtube' | 'reddit' | 'twitter' | 'manual'
  viewCount   BigInt?
  explanation String?
  isActive    Boolean  @default(true)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@unique([text, platform])
  @@index([platform, isActive])
  @@index([score, isActive])
  @@index([niche, isActive])
  @@index([expiresAt])
  @@map("trending_hooks")
}
